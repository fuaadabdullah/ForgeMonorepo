# =====================================================
# Goblin Assistant Environment Configuration
# =====================================================
# Copy this file to .env.local and fill in your actual values
# DO NOT commit .env.local to version control
#
# Required values are marked [REQUIRED]
# Optional values are marked [OPTIONAL]
# =====================================================

# =====================================================
# ENVIRONMENT & RUNTIME
# =====================================================
ENVIRONMENT=development                    # development | staging | production [REQUIRED]
ALLOW_MEMORY_FALLBACK=true                # Allow in-memory fallback if Redis unavailable [OPTIONAL]

# =====================================================
# DATABASE (REQUIRED)
# =====================================================
DATABASE_URL=postgresql://postgres:password@localhost:5432/goblin_assistant
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=paste_your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=paste_your_service_role_key_here

# =====================================================
# CACHE & SESSION STORAGE
# =====================================================
REDIS_URL=redis://default:password@your-redis-host:6379

# =====================================================
# ENCRYPTION KEYS (PRODUCTION ONLY - REQUIRED)
# =====================================================
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
ROUTING_ENCRYPTION_KEY=paste_your_encryption_key_here
SETTINGS_ENCRYPTION_KEY=paste_your_settings_encryption_key_here

# =====================================================
# AUTHENTICATION
# =====================================================
JWT_SECRET_KEY=your-secret-key-change-in-production    # [REQUIRED]
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# Email validation
REQUIRE_EMAIL_VALIDATION=true
ALLOW_DISPOSABLE_EMAILS=false
CHALLENGE_TTL=300                         # Challenge token TTL in seconds

# Turnstile CAPTCHA (if using Cloudflare)
TURNSTILE_SECRET_KEY=paste_your_turnstile_secret_here  # [OPTIONAL]
TURNSTILE_SITE_KEY=paste_your_turnstile_site_key_here  # [OPTIONAL]

# =====================================================
# LLM PROVIDERS - GCP INSTANCES
# =====================================================
# GCP Ollama endpoint (with RAG support)
OLLAMA_GCP_BASE_URL=http://34.55.121.214:11434
OLLAMA_GCP_URL=http://34.55.121.214:11434
OLLAMA_GCP_API_KEY=paste_your_ollama_api_key_here      # [REQUIRED for production]

# GCP LlamaCPP endpoint
LLAMACPP_GCP_BASE_URL=http://34.123.36.255:8000
LLAMACPP_GCP_URL=http://34.123.36.255:8000
LLAMACPP_GCP_API_KEY=paste_your_llamacpp_api_key_here  # [REQUIRED for production]

# Shared model-server API key for GCP Ollama/LlamaCPP endpoints
LOCAL_LLM_API_KEY=paste_your_model_server_api_key_here # [REQUIRED for production]

# =====================================================
# LLM PROVIDERS - CLOUD FALLBACKS
# =====================================================
OPENAI_API_KEY=sk-paste-your-openai-key-here
ANTHROPIC_API_KEY=paste_your_anthropic_key_here
DEEPSEEK_API_KEY=paste_your_deepseek_key_here
GEMINI_API_KEY=paste_your_gemini_key_here
OPENROUTER_API_KEY=sk-or-v1-paste-your-openrouter-key-here
TAVILY_API_KEY=tvly-paste-your-tavily-api-key-here     # For RAG search

# Azure OpenAI
AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com
AZURE_API_KEY=paste_your_azure_openai_key_here
AZURE_DEPLOYMENT_ID=chat-prod
AZURE_API_VERSION=2024-08-01-preview
AZURE_DEFAULT_MODEL=gpt-4o-mini

# Aliyun model server
ALIYUN_MODEL_SERVER_URL=https://your-aliyun-model-server.example
ALIYUN_MODEL_SERVER_KEY=paste_your_aliyun_server_key_here
ALIYUN_DEFAULT_MODEL=qwen2.5:3b

# RunPod (for compute tasks)
RUNPOD_API_KEY=rpa_paste_your_runpod_key_here
RUNPOD_S3_KEY=rps_paste_your_runpod_s3_key_here

# Vast.ai (for batch training - NOT for real-time inference)
VASTAI_API_KEY=paste_your_vastai_api_key_here

# =====================================================
# GCP CLOUD STORAGE
# =====================================================
GCS_PROJECT_ID=goblin-assistant-llm
GCS_REGION=us-east1
GCS_MODEL_BUCKET=goblin-llm-models

# =====================================================
# AI/ML FEATURES
# =====================================================
# Disable local ML runtime inside API deployment containers.
# Keep this true on Render backend and run ML workloads on dedicated model servers.
DISABLE_LOCAL_ML=true

# RAG (Retrieval-Augmented Generation)
# Keep false for API-only deployments. Host vector/embedding workloads separately.
ENABLE_ENHANCED_RAG=false
RAG_CHROMA_PATH=data/vector/chroma
RAG_API_KEY=dev-key                       # API key for RAG endpoints

# Model & provider selection strategy
DEFAULT_ROUTING_STRATEGY=LOWEST_LATENCY   # LOWEST_LATENCY | LOWEST_COST | ROUND_ROBIN | FAILOVER

# =====================================================
# LICENSING
# =====================================================
LICENSE_KEYS=dev-free:free,dev-pro:pro,dev-enterprise:enterprise
DEFAULT_LICENSE_TIER=free
ENFORCE_LICENSING=false                   # Set to true to enforce license validation

# =====================================================
# LOGGING & DEBUGGING
# =====================================================
LOG_LEVEL=INFO                            # DEBUG | INFO | WARNING | ERROR | CRITICAL
DEBUG_AUTH=false

# =====================================================
# MONITORING & OBSERVABILITY
# =====================================================
SENTRY_DSN=                               # [OPTIONAL] Sentry error tracking DSN

# =====================================================
# FRONTEND (Next.js) - PUBLIC VARIABLES
# =====================================================
# These are baked into the client bundle - safe to expose
NEXT_PUBLIC_API_BASE_URL=https://goblin-backend.onrender.com
NEXT_PUBLIC_BACKEND_URL=https://goblin-backend.onrender.com

# Feature flags
NEXT_PUBLIC_FEATURE_RAG_ENABLED=false
NEXT_PUBLIC_FEATURE_MULTI_PROVIDER=true
NEXT_PUBLIC_FEATURE_PASSKEY_AUTH=true
NEXT_PUBLIC_FEATURE_GOOGLE_AUTH=true
NEXT_PUBLIC_FEATURE_ORCHESTRATION=true
NEXT_PUBLIC_FEATURE_SANDBOX=true
NEXT_PUBLIC_FEATURE_SEARCH=true
NEXT_PUBLIC_ENABLE_ANALYTICS=true

# Turnstile (public key for frontend)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=paste_your_turnstile_site_key_here

# RAG UI
NEXT_PUBLIC_RAG_API_KEY=dev-key

# =====================================================
# FRONTEND (Next.js) - PROTECTED SERVER-SIDE SECRETS
# =====================================================
# These must be set in Vercel Dashboard (NOT in vercel.json)
# Do NOT expose to browser
GOBLIN_BACKEND_URL=https://goblin-backend.onrender.com      # Server-side only
INTERNAL_PROXY_API_KEY=change-me-in-production          # Shared Next -> FastAPI proxy key

# =====================================================
# DEPLOYMENT - RENDER (PRIMARY)
# =====================================================
# Render Blueprint file: render.yaml
# Set these in Render dashboard/service environment:
# Required:
# - DATABASE_URL
# - REDIS_URL
# - JWT_SECRET_KEY
# - ROUTING_ENCRYPTION_KEY
# - SETTINGS_ENCRYPTION_KEY
# - INTERNAL_PROXY_API_KEY
# - CORS_ORIGINS
# Provider-dependent:
# - OPENAI_API_KEY
# - ANTHROPIC_API_KEY
# - GEMINI_API_KEY
# - DEEPSEEK_API_KEY
# - OPENROUTER_API_KEY
# - TAVILY_API_KEY
# - OLLAMA_GCP_URL
# - LLAMACPP_GCP_URL
# - LOCAL_LLM_API_KEY
# - SUPABASE_SERVICE_ROLE_KEY
# - SENTRY_DSN
#
# Optional deploy helper variables:
RENDER_BACKEND_URL=https://goblin-backend.onrender.com
RENDER_DEPLOY_HOOK_URL=

# =====================================================
# CORS CONFIGURATION
# =====================================================
CORS_ORIGINS=https://goblin-assistant.vercel.app,https://goblin-assistant-*.vercel.app,http://localhost:3000,http://localhost:5173

# =====================================================
# DEVELOPMENT SETTINGS (local .env.local)
# =====================================================
# Admin secrets (development only)
ALHUB_API_KEY=sk-paste_dev_key_here

# Cloud model server overrides
# OLLAMA_GCP_BASE_URL=https://<your-gcp-ollama-endpoint>
# LLAMACPP_GCP_BASE_URL=https://<your-gcp-llamacpp-endpoint>
